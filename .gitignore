# Misc
# =============================================================================

# Temp / editor junk
~$*
*~
*.tmp
*.bak
# GitHub Copilot CLI — local session state (plans, artifacts — never committed)
.copilot/

# Claude Code — keep shared config, ignore personal/local/temp
.claude/settings.local.json
.claude/.compact-marker.json
.claude/logs/


# Git worktrees (local development isolation)
.worktrees/


# Git worktrees (local development isolation)
.worktrees/

# Dev certificates (generated by dev-certs/setup-certs.cmd)
dev-certs/certs/
dev-certs/mkcert.exe

# MCP local overrides (personal credentials — use .mcp.local.json)
# .mcp.json is tracked (team-shared, secrets via env vars)
src/Identity.API/keys/

# Superpowers plans/specs and research docs (local dev artifacts)
docs/superpowers/
docs/research/

