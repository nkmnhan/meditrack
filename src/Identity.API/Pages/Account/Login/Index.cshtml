@page
@model MediTrack.Identity.Pages.Account.Login.Index

<div class="auth-page">
    <partial name="_AuthBranding" />

    <!-- Right form panel -->
    <div class="auth-form-panel">
        <div class="auth-form">
            <!-- Mobile branding (hidden on desktop) -->
            <div class="auth-mobile-brand">
                <div class="auth-mobile-brand-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M4.8 2.3A.3.3 0 1 0 5 2H4a2 2 0 0 0-2 2v5a6 6 0 0 0 6 6v0a6 6 0 0 0 6-6V4a2 2 0 0 0-2-2h-1a.2.2 0 1 0 .3.3" /><path d="M8 15v1a6 6 0 0 0 6 6v0a6 6 0 0 0 6-6v-4" /><circle cx="20" cy="10" r="2" />
                    </svg>
                </div>
                <h1>MediTrack</h1>
            </div>

            @if (Model.View.EnableLocalLogin)
            {
                <form asp-page="/Account/Login/Index" method="post">
                    <input type="hidden" asp-for="Input.ReturnUrl" />

                    <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

                    <h2 class="auth-heading">Welcome back</h2>
                    <p class="auth-subheading">Sign in to your account</p>

                    <!-- Email -->
                    <div class="form-group">
                        <label asp-for="Input.Username" class="form-label">Email address</label>
                        <div class="input-wrapper">
                            <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2" /><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" /></svg>
                            <input asp-for="Input.Username" class="form-input form-input-icon" placeholder="doctor@meditrack.com" autofocus autocomplete="email" />
                        </div>
                    </div>

                    <!-- Password -->
                    <div class="form-group">
                        <label asp-for="Input.Password" class="form-label">Password</label>
                        <div class="input-wrapper">
                            <svg class="input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2" /><path d="M7 11V7a5 5 0 0 1 10 0v4" /></svg>
                            <input asp-for="Input.Password" type="password" class="form-input form-input-icon" placeholder="Enter your password" autocomplete="current-password" />
                        </div>
                    </div>

                    @if (Model.View.AllowRememberLogin)
                    {
                        <div class="form-group-inline">
                            <input asp-for="Input.RememberLogin" type="checkbox" />
                            <label asp-for="Input.RememberLogin">Remember me</label>
                        </div>
                    }

                    <button class="btn btn-primary" name="Input.Button" value="login">Sign In</button>

                    <p class="auth-link">
                        Don't have an account? <a asp-page="/Account/Register/Index" asp-route-returnUrl="@Model.Input.ReturnUrl">Register here</a>
                    </p>

                    @if (Model.View.VisibleExternalProviders.Any())
                    {
                        <div class="divider">
                            <hr class="divider-line" />
                            <span class="divider-text">or</span>
                        </div>

                        <div class="external-providers">
                            @foreach (var provider in Model.View.VisibleExternalProviders)
                            {
                                <a class="btn btn-secondary btn-external"
                                   asp-page="/Account/ExternalLogin"
                                   asp-route-scheme="@provider.AuthenticationScheme"
                                   asp-route-returnUrl="@Model.Input.ReturnUrl">
                                    @provider.DisplayName
                                </a>
                            }
                        </div>
                    }
                </form>
            }
            else if (Model.View.VisibleExternalProviders.Any())
            {
                <h2 class="auth-heading">Welcome back</h2>
                <p class="auth-subheading">Sign in with your provider</p>
                <div class="external-providers">
                    @foreach (var provider in Model.View.VisibleExternalProviders)
                    {
                        <a class="btn btn-secondary btn-external"
                           asp-page="/Account/ExternalLogin"
                           asp-route-scheme="@provider.AuthenticationScheme"
                           asp-route-returnUrl="@Model.Input.ReturnUrl">
                            @provider.DisplayName
                        </a>
                    }
                </div>
            }
            else
            {
                <div class="alert alert-danger">No login schemes configured for this client.</div>
            }
        </div>
    </div>
</div>
