# ============================================================
#  MediTrack — Environment Variables
#  Copy this file to the project root as .env:
#    cp .env.example .env        (Linux / macOS / Git Bash)
#    copy .env.example .env      (Windows CMD)
#
#  Docker Compose auto-loads .env from the directory where
#  docker-compose.yml lives (the project root).
# ============================================================

# ── Database ─────────────────────────────────────────────────
POSTGRES_USER=meditrack
POSTGRES_PASSWORD=MediTrack_Dev@2026!

# ── Message Broker ───────────────────────────────────────────
RABBITMQ_DEFAULT_USER=meditrack
RABBITMQ_DEFAULT_PASS=meditrack_secret
RABBITMQ_DEFAULT_VHOST=/

# ── AI — Cloud tier (required for docker-cloud / nexus-cloud) ─
# Claude (LLM for suggestions)      https://console.anthropic.com
CLAUDE_TOKEN=

# OpenAI (embeddings / RAG)          https://platform.openai.com
OPENAI_API_KEY=sk-placeholder-for-dev

# Deepgram (real-time cloud STT)    https://console.deepgram.com
DEEP_GRAM_TOKEN=

# ── STT Provider ─────────────────────────────────────────────
# Deepgram  = cloud, real-time, ~200 ms latency (cloud modes)
# Whisper   = self-hosted, batch, ~5 s latency  (local modes)
STT_PROVIDER=Deepgram

# ── Whisper — Local tier (docker-local / nexus-local) ────────
# Only used when STT_PROVIDER=Whisper
WHISPER_BASE_URL=http://whisper-api:8000
WHISPER_MODEL=base.en

# ── OpenTelemetry ─────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# ── Service URLs (identity / inter-service) ───────────────────
IDENTITY_URL=http://identity-api:8080
SERVICE_CLIENT_SECRET=change-me-in-production

# ── Simulator (optional overrides — defaults in appsettings.json) ─
# Simulator__ClearExisting=false
# Simulator__PatientCount=50
# Simulator__AppointmentsPerPatient=3
# Simulator__MedicalRecordsPerPatient=3
# Simulator__AuditLogCount=15000
# Simulator__ClaraSessionCount=2500

# ── Vite / Frontend ───────────────────────────────────────────
VITE_IDENTITY_URL=https://localhost:5001
VITE_PATIENT_API_URL=https://localhost:5002
VITE_APPOINTMENT_API_URL=https://localhost:5003
VITE_MEDICALRECORDS_API_URL=https://localhost:5004
