# ============================================================
#  MediTrack — Environment Variables
#  Copy this file to the PROJECT ROOT as .env
#  Docker Compose auto-loads .env from the directory where
#  docker-compose.yml lives (the project root).
# ============================================================

# ── Database ─────────────────────────────────────────────────
POSTGRES_USER=meditrack
POSTGRES_PASSWORD=MediTrack_Dev@2026!

# ── Message Broker ───────────────────────────────────────────
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest

# ── AI — Paid tier ───────────────────────────────────────────
# Claude (LLM for suggestions)      https://console.anthropic.com
CLAUDE_TOKEN=

# OpenAI (embeddings / RAG)          https://platform.openai.com
OPENAI_API_KEY=sk-placeholder-for-dev

# Deepgram (real-time cloud STT)    https://console.deepgram.com
DEEP_GRAM_TOKEN=

# ── STT Provider ─────────────────────────────────────────────
# Deepgram  = cloud, real-time, paid
# Whisper   = self-hosted, batch (~5 s delay), free
STT_PROVIDER=Deepgram

# ── Whisper — Free tier ──────────────────────────────────────
# Only used when STT_PROVIDER=Whisper
WHISPER_BASE_URL=http://whisper-api:8000
WHISPER_MODEL=base.en
